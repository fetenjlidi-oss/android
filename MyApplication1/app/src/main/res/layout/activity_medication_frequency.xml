<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F0EFEB">

    <!-- Back Button -->
    <ImageButton
        android:id="@+id/btnBack"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:src="@drawable/ic_progress"
        android:background="@drawable/bg_circle_white"
        android:padding="8dp"
        android:layout_marginTop="16dp"
        android:layout_marginStart="16dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"/>

    <!-- Medicine Illustration -->
    <ImageView
        android:id="@+id/imgIllustration"
        android:layout_width="110dp"
        android:layout_height="110dp"
        android:src="@drawable/ic_medicine"
        android:layout_marginTop="12dp"
        app:layout_constraintTop_toBottomOf="@id/btnBack"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- Step indicator -->
    <TextView
        android:id="@+id/tvStep"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="2"
        android:textSize="12sp"
        android:textColor="#AAAAAA"
        android:layout_marginTop="12dp"
        android:layout_marginStart="20dp"
        app:layout_constraintTop_toBottomOf="@id/imgIllustration"
        app:layout_constraintStart_toStartOf="parent"/>

    <!-- Question Title -->
    <TextView
        android:id="@+id/tvQuestion"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="How often do you take this medication?"
        android:textSize="18sp"
        android:textColor="#1A0F0F"
        android:lineSpacingExtra="4dp"
        android:layout_marginTop="4dp"
        android:layout_marginStart="20dp"
        android:layout_marginEnd="20dp"
        app:layout_constraintTop_toBottomOf="@id/tvStep"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- Options List -->
    <RadioGroup
        android:id="@+id/radioGroup"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_marginTop="20dp"
        android:layout_marginStart="20dp"
        android:layout_marginEnd="20dp"
        app:layout_constraintTop_toBottomOf="@id/tvQuestion"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- Once daily -->
        <RadioButton
            android:id="@+id/radioOnceDaily"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="Once daily"
            android:textSize="15sp"
            android:textColor="#1A0F0F"
            android:buttonTint="#1A0F0F"
            android:gravity="center_vertical"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:layoutDirection="rtl"
            android:background="@drawable/bg_radio_option"/>

        <!-- Twice daily -->
        <RadioButton
            android:id="@+id/radioTwiceDaily"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="Twice daily"
            android:textSize="15sp"
            android:textColor="#1A0F0F"
            android:buttonTint="#1A0F0F"
            android:gravity="center_vertical"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:layoutDirection="rtl"
            android:layout_marginTop="8dp"
            android:background="@drawable/bg_radio_option"/>

        <!-- On demand -->
        <RadioButton
            android:id="@+id/radioOnDemand"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="On demand (no reminder needed)"
            android:textSize="15sp"
            android:textColor="#1A0F0F"
            android:buttonTint="#1A0F0F"
            android:gravity="center_vertical"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:layoutDirection="rtl"
            android:layout_marginTop="8dp"
            android:background="@drawable/bg_radio_option"/>

        <!-- More options -->
        <RadioButton
            android:id="@+id/radioMoreOptions"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="I need more options..."
            android:textSize="15sp"
            android:textColor="#1A0F0F"
            android:buttonTint="#1A0F0F"
            android:gravity="center_vertical"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:layoutDirection="rtl"
            android:layout_marginTop="8dp"
            android:background="@drawable/bg_radio_option"/>

    </RadioGroup>

    <!-- Progress indicator -->
    <View
        android:id="@+id/progressIndicator"
        android:layout_width="60dp"
        android:layout_height="4dp"
        android:background="@drawable/bg_action_purple"
        android:layout_marginBottom="90dp"
        app:layout_constraintBottom_toTopOf="@id/btnNext"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- Next Button -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnNext"
        android:layout_width="0dp"
        android:layout_height="56dp"
        android:layout_marginStart="20dp"
        android:layout_marginEnd="20dp"
        android:layout_marginBottom="24dp"
        android:text="Next"
        android:textSize="16sp"
        android:textStyle="bold"
        android:textColor="#FFFFFF"
        android:enabled="false"
        app:cornerRadius="30dp"
        app:backgroundTint="#BBBBBB"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

</androidx.constraintlayout.widget.ConstraintLayout>