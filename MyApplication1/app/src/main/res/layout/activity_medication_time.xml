<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F0EFEB">

    <!-- Back Button -->
    <ImageButton
        android:id="@+id/btnBack"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:src="@drawable/ic_progress"
        android:background="@drawable/bg_circle_white"
        android:padding="8dp"
        android:layout_marginTop="16dp"
        android:layout_marginStart="16dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"/>

    <!-- Medicine Illustration -->
    <ImageView
        android:id="@+id/imgMedicine"
        android:layout_width="100dp"
        android:layout_height="100dp"
        android:src="@drawable/ic_medicine"
        android:layout_marginTop="16dp"
        app:layout_constraintTop_toBottomOf="@id/btnBack"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- Question Title -->
    <TextView
        android:id="@+id/tvQuestion"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="What time do you usually take your first medication?"
        android:textSize="18sp"
        android:textColor="#1A0F0F"
        android:lineSpacingExtra="4dp"
        android:layout_marginTop="16dp"
        android:layout_marginStart="20dp"
        android:layout_marginEnd="20dp"
        app:layout_constraintTop_toBottomOf="@id/imgMedicine"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- Scrollable Radio Options -->
    <androidx.core.widget.NestedScrollView
        android:id="@+id/scrollView"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginTop="16dp"
        android:layout_marginBottom="8dp"
        app:layout_constraintTop_toBottomOf="@id/tvQuestion"
        app:layout_constraintBottom_toTopOf="@id/tvSkip"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <RadioGroup
            android:id="@+id/radioGroup"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="20dp"
            android:paddingEnd="20dp">

            <!-- 06:00 -->
            <RadioButton
                android:id="@+id/radio0600"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:text="06:00"
                android:textSize="15sp"
                android:textColor="#1A0F0F"
                android:buttonTint="#1A0F0F"
                android:gravity="center_vertical"
                android:layoutDirection="rtl"
                android:paddingEnd="4dp"
                android:background="@drawable/bg_radio_item"/>

            <!-- 07:00 -->
            <RadioButton
                android:id="@+id/radio0700"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:text="07:00"
                android:textSize="15sp"
                android:textColor="#1A0F0F"
                android:buttonTint="#1A0F0F"
                android:gravity="center_vertical"
                android:layoutDirection="rtl"
                android:paddingEnd="4dp"
                android:layout_marginTop="1dp"
                android:background="@drawable/bg_radio_item"/>

            <!-- 08:00 -->
            <RadioButton
                android:id="@+id/radio0800"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:text="08:00"
                android:textSize="15sp"
                android:textColor="#1A0F0F"
                android:buttonTint="#1A0F0F"
                android:gravity="center_vertical"
                android:layoutDirection="rtl"
                android:paddingEnd="4dp"
                android:layout_marginTop="1dp"
                android:checked="true"
                android:background="@drawable/bg_radio_item"/>

            <!-- 09:00 -->
            <RadioButton
                android:id="@+id/radio0900"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:text="09:00"
                android:textSize="15sp"
                android:textColor="#1A0F0F"
                android:buttonTint="#1A0F0F"
                android:gravity="center_vertical"
                android:layoutDirection="rtl"
                android:paddingEnd="4dp"
                android:layout_marginTop="1dp"
                android:background="@drawable/bg_radio_item"/>

            <!-- 10:00 -->
            <RadioButton
                android:id="@+id/radio1000"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:text="10:00"
                android:textSize="15sp"
                android:textColor="#1A0F0F"
                android:buttonTint="#1A0F0F"
                android:gravity="center_vertical"
                android:layoutDirection="rtl"
                android:paddingEnd="4dp"
                android:layout_marginTop="1dp"
                android:background="@drawable/bg_radio_item"/>

            <!-- 11:00 -->
            <RadioButton
                android:id="@+id/radio1100"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:text="11:00"
                android:textSize="15sp"
                android:textColor="#1A0F0F"
                android:buttonTint="#1A0F0F"
                android:gravity="center_vertical"
                android:layoutDirection="rtl"
                android:paddingEnd="4dp"
                android:layout_marginTop="1dp"
                android:background="@drawable/bg_radio_item"/>

            <!-- Other -->
            <RadioButton
                android:id="@+id/radioOther"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:text="Other"
                android:textSize="15sp"
                android:textColor="#1A0F0F"
                android:buttonTint="#1A0F0F"
                android:gravity="center_vertical"
                android:layoutDirection="rtl"
                android:paddingEnd="4dp"
                android:layout_marginTop="1dp"
                android:background="@drawable/bg_radio_item"/>

        </RadioGroup>
    </androidx.core.widget.NestedScrollView>

    <!-- Skip -->
    <TextView
        android:id="@+id/tvSkip"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Skip"
        android:textSize="15sp"
        android:textColor="#C9A227"
        android:textStyle="bold"
        android:layout_marginBottom="12dp"
        app:layout_constraintBottom_toTopOf="@id/btnNext"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- Next Button -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnNext"
        android:layout_width="0dp"
        android:layout_height="56dp"
        android:layout_marginStart="20dp"
        android:layout_marginEnd="20dp"
        android:layout_marginBottom="24dp"
        android:text="Next"
        android:textSize="16sp"
        android:textStyle="bold"
        android:textColor="#FFFFFF"
        app:cornerRadius="30dp"
        app:backgroundTint="#1A0F0F"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

</androidx.constraintlayout.widget.ConstraintLayout>